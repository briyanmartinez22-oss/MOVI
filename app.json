{
  "expo": {
    "name": "MOVI",
    "slug": "MOVI",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "movi",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "bundleIdentifier": "com.movi.app",
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "MOVI usa tu ubicación para solicitar viajes y mostrar conductores cercanos.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "MOVI usa tu ubicación para el seguimiento de viajes en curso.",
        "NSCameraUsageDescription": "MOVI usa la cámara para verificar documentos y fotos de perfil.",
        "NSPhotoLibraryUsageDescription": "MOVI accede a tus fotos para subir documentos y comprobantes.",
        "UIBackgroundModes": [
          "location",
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.movi.app",
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "MOVI usa tu ubicación para solicitar viajes y mostrar conductores cercanos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#E10600",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "MOVI accede a tus fotos para subir documentos y comprobantes.",
          "cameraPermission": "MOVI usa la cámara para verificar documentos y fotos de perfil."
        }
      ]
    ],
    "extra": {
      "EXPO_PUBLIC_USE_MOCK_API": "false",
      "EXPO_PUBLIC_API_URL": "https://movi-production-ef3b.up.railway.app",
      "EXPO_PUBLIC_WS_URL": "wss://movi-production-ef3b.up.railway.app/ws",
      "eas": {
        "projectId": "39a33436-1ef3-4b71-a835-b4cc22a4cde2"
      },
      "router": {}
    },
    "owner": "briyangm"
  }
}
