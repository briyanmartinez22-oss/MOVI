{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://movi-production-ef3b.up.railway.app",
        "EXPO_PUBLIC_WS_URL": "wss://movi-production-ef3b.up.railway.app/ws",
        "EXPO_PUBLIC_USE_MOCK_API": "false"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://movi-production-ef3b.up.railway.app",
        "EXPO_PUBLIC_WS_URL": "wss://movi-production-ef3b.up.railway.app/ws",
        "EXPO_PUBLIC_USE_MOCK_API": "false"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
