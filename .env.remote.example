# MOVI — variables para pruebas remotas (testers en El Salvador)
# Copiar a .env en la raíz del proyecto antes de iniciar Expo:
#   cp .env.remote.example .env

# --- Expo (obligatorias en la raíz del repo) ---
EXPO_PUBLIC_API_URL=https://REEMPLAZAR_CON_URL_PUBLICA_DEL_BACKEND
EXPO_PUBLIC_WS_URL=wss://REEMPLAZAR_CON_URL_PUBLICA_DEL_BACKEND/ws
EXPO_PUBLIC_USE_MOCK_API=false

# --- Backend (configurar en Railway/Render, NO en este archivo .env de Expo) ---
# PORT=3001
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/movi?schema=public
# JWT_SECRET=generar-string-largo-aleatorio-min-32-chars

# --- Instrucciones rápidas ---
# 1. Desplegar backend (ver DEPLOYMENT_GUIDE.md)
# 2. Confirmar GET https://TU_URL/health → status ok, database connected
# 3. Ejecutar seed contra la DB remota (ver DEPLOYMENT_GUIDE.md)
# 4. Reemplazar REEMPLAZAR_CON_URL_PUBLICA_DEL_BACKEND con tu URL real
# 5. Desde Dallas (o cualquier red): npx expo start --tunnel
# 6. Enviar QR a testers en El Salvador con Expo Go
