# --- Database (PostgreSQL required) ---
# Railway: reference ${{Postgres.DATABASE_URL}} in the service variables panel
DATABASE_URL="postgresql://movi:movi@localhost:5432/movi?schema=public"

# Local PostgreSQL via Docker:
#   docker compose up -d
# Then use the DATABASE_URL above.

# --- Server ---
PORT=3001
NODE_ENV=development
PUBLIC_URL="http://localhost:3001"

# --- Security ---
JWT_SECRET="change-me-in-production-use-long-random-string"
CORS_ORIGIN="*"

# --- OTP / SMS ---
DEMO_OTP_CODE="123456"

# Twilio (production SMS — optional; without it OTP is logged to console)
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_FROM_NUMBER=""

# --- File storage ---
STORAGE_MODE=local

# S3 (production uploads)
# STORAGE_MODE=s3
# AWS_S3_BUCKET=""
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION="us-east-1"
# AWS_S3_PUBLIC_URL_PREFIX=""

# --- Remote QA scripts (optional, run from local machine) ---
# API_URL="https://your-backend.up.railway.app"
# WS_URL="wss://your-backend.up.railway.app/ws"
