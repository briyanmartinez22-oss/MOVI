# --- Database (PostgreSQL required) ---
# Railway: reference ${{Postgres.DATABASE_URL}} in the service variables panel
DATABASE_URL="postgresql://movi:movi@localhost:5432/movi?schema=public"

# --- Server ---
PORT=3001
NODE_ENV=development
PUBLIC_URL="http://localhost:3001"

# --- Security ---
JWT_SECRET="change-me-in-production-use-long-random-string"
CORS_ORIGIN="*"

# --- OTP ---
# Demo OTP only for development (never in production)
DEMO_OTP_CODE="123456"
OTP_PROVIDER=demo

# Twilio (production OTP)
# OTP_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_FROM_NUMBER=""
# TWILIO_VERIFY_SERVICE_SID=""

# --- File storage ---
# STORAGE_PROVIDER=local | s3 | cloudinary
# Si no se define STORAGE_PROVIDER y existen credenciales Cloudinary, se usa Cloudinary automáticamente.
STORAGE_PROVIDER=local

# Cloudinary (producción — imágenes/documentos de verificación)
# STORAGE_PROVIDER=cloudinary
# CLOUDINARY_CLOUD_NAME=dtvrbxqnm
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""
# CLOUDINARY_FOLDER=movi

# S3 / R2
# STORAGE_PROVIDER=s3
# S3_BUCKET=""
# S3_REGION="us-east-1"
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
# AWS_S3_PUBLIC_URL_PREFIX=""

# --- Maps ---
# MAPS_PROVIDER=fallback | google | mapbox
# Si no se define MAPS_PROVIDER y existe GOOGLE_MAPS_API_KEY, se usa Google automáticamente.
MAPS_PROVIDER=google
# GOOGLE_MAPS_API_KEY=""
# MAPBOX_ACCESS_TOKEN=""

# --- Push notifications ---
# PUSH_PROVIDER=none | expo | firebase
PUSH_PROVIDER=none
# EXPO_ACCESS_TOKEN=""
# FIREBASE_PROJECT_ID=""
# FIREBASE_CLIENT_EMAIL=""
# FIREBASE_PRIVATE_KEY=""

# --- Remote QA scripts (optional) ---
# API_URL="https://your-backend.up.railway.app"
# WS_URL="wss://your-backend.up.railway.app/ws"
