generator client {
  provider = "prisma-client-js"
}

// PostgreSQL only — local dev: docker compose up -d (see docker-compose.yml)
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  passenger
  driver
  owner
  business
  admin
}

enum OwnerVerificationStatus {
  pending
  documents_uploaded
  selfie_pending
  under_review
  approved
  rejected
  suspended
}

enum VehicleVerificationStatus {
  draft
  documents_uploaded
  under_review
  approved
  rejected
  suspended
}

enum DriverVerificationStatus {
  pending
  approved
  rejected
  suspended
}

enum BusinessStatus {
  pending
  approved
  rejected
}

enum SubscriptionStatus {
  trial_until_next_month
  active
  past_due
  suspended
}

enum VehicleType {
  mototaxi
  qute
  motocicleta
  sedan
  camioneta
  pickup
  camion
  microbus
  tuk_tuk_red
}

enum BusinessType {
  restaurant
  store
  pharmacy
  commerce
  startup
  other
}

enum ServiceType {
  RIDE
  DELIVERY
  PACKAGE
  CARGO
  MOVING
  ANIMAL_TRANSPORT
  GROUP_TRANSPORT
  BUSINESS_SERVICE
}

enum VerificationDocumentStatus {
  pending
  under_review
  approved
  rejected
  expired
}

enum VerificationDocumentType {
  dui_front
  dui_back
  license_front
  license_back
  vehicle_registration
  vehicle_insurance
  ownership_proof
  selfie
  business_license
  other
}

enum PaymentStatus {
  pending
  processing
  completed
  failed
  refunded
  cancelled
}

enum NotificationType {
  trip_update
  offer_received
  payment
  verification
  system
  marketing
  support
}

enum SupportTicketStatus {
  open
  in_progress
  waiting_on_user
  resolved
  closed
}

enum SupportTicketPriority {
  low
  medium
  high
  urgent
}

enum AuditAction {
  create
  update
  delete
  login
  logout
  verify
  approve
  reject
  cancel
}

model User {
  id            String   @id @default(cuid())
  fullName      String
  phoneNumber   String   @unique
  duiNumber     String
  role          UserRole
  phoneVerified Boolean  @default(false)
  profilePhoto  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  owner              Owner?
  driver             Driver?
  business           Business?
  roleAssignments    UserRoleAssignment[]
  refreshTokens      RefreshToken[]
  verificationDocs   VerificationDocument[]
  payments           Payment[]
  notifications      Notification[]
  pushTokens         PushToken[]
  supportTickets     SupportTicket[]
  auditLogs          AuditLog[]
  locationPings      LocationPing[]
}

model UserRoleAssignment {
  id        String   @id @default(cuid())
  userId    String
  role      UserRole
  isActive  Boolean  @default(true)
  grantedAt DateTime @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([userId])
  @@index([role])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  deviceId  String?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model OtpChallenge {
  id          String   @id @default(cuid())
  phoneNumber String
  code        String
  expiresAt   DateTime
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([phoneNumber])
}

model Owner {
  id                  String                  @id @default(cuid())
  userId              String                  @unique
  name                String
  phone               String
  dui                 String
  status              OwnerVerificationStatus @default(pending)
  documentsJson       String                  @default("{}")
  specialCase         String?
  ownershipProofImage String?
  createdAt           DateTime                @default(now())

  user               User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicles           Vehicle[]
  drivers            Driver[]
  invites            InviteCode[]
  verificationDocs   VerificationDocument[]
}

model Vehicle {
  id               String                    @id @default(cuid())
  unitId           String                    @unique
  ownerId          String
  unitNumber       String
  plateNumber      String                    @unique
  registrationName String?
  associationName  String
  vehicleType      VehicleType               @default(mototaxi)
  status           VehicleVerificationStatus @default(draft)
  documentsJson    String                    @default("{}")
  maxLoadKg        Float?
  bedLengthM       Float?
  hasCargoCover    Boolean?
  brand            String?
  model            String?
  year             Int?
  color            String?
  passengerCapacity Int?
  cargoCapacity    Float?
  photosJson       String                    @default("[]")
  registrationCard String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  owner              Owner                  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  driver             Driver?
  invites            InviteCode[]
  sessions           DriverSession[]
  assignments        VehicleAssignment[]
  tripOffers         TripOffer[]
  verificationDocs   VerificationDocument[]
}

model VehicleAssignment {
  id           String    @id @default(cuid())
  driverId     String
  vehicleId    String
  isActive     Boolean   @default(true)
  assignedAt   DateTime  @default(now())
  unassignedAt DateTime?
  notes        String?

  driver  Driver  @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([driverId])
  @@index([vehicleId])
  @@index([isActive])
}

model Driver {
  id             String                   @id
  userId         String                   @unique
  ownerId        String
  vehicleId      String                   @unique
  name           String
  phone          String
  status         DriverVerificationStatus @default(pending)
  inviteCodeUsed String?
  rating         Float                    @default(5)
  totalTrips     Int                      @default(0)
  createdAt      DateTime                 @default(now())

  user               User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  owner              Owner                  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  vehicle            Vehicle                @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  subscription       DriverSubscription?
  sessions           DriverSession[]
  vehicleAssignments VehicleAssignment[]
  tripOffers         TripOffer[]
  locationPings      LocationPing[]
  verificationDocs   VerificationDocument[]
}

model VerificationDocument {
  id           String                   @id @default(cuid())
  userId       String?
  ownerId      String?
  driverId     String?
  vehicleId    String?
  documentType VerificationDocumentType
  fileUrl      String
  storageKey   String?
  mimeType     String?
  sizeBytes    Int?
  status       VerificationDocumentStatus @default(pending)
  reviewedBy   String?
  reviewNotes  String?
  metadataJson String                   @default("{}")
  uploadedAt   DateTime                 @default(now())
  reviewedAt   DateTime?
  expiresAt    DateTime?

  user    User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  owner   Owner?   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  driver  Driver?  @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([ownerId])
  @@index([driverId])
  @@index([vehicleId])
  @@index([status])
}

model Business {
  id              String         @id @default(cuid())
  userId          String         @unique
  businessName    String
  businessType    BusinessType
  responsibleDui  String
  businessPhone   String
  nit             String?
  latitude        Float
  longitude       Float
  addressLabel    String
  status          BusinessStatus @default(pending)
  rating          Float          @default(5)
  totalDeliveries Int            @default(0)
  createdAt       DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DriverSubscription {
  id               String             @id @default(cuid())
  driverId         String             @unique
  status           SubscriptionStatus @default(trial_until_next_month)
  monthlyAmountUsd Float              @default(7)
  registeredAt     DateTime           @default(now())
  trialEndsAt      DateTime
  nextBillingAt    DateTime
  paymentMethod    String?
  paymentProvider  String?
  lastPaidAt       DateTime?

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)
}

model InviteCode {
  code      String    @id
  vehicleId String
  ownerId   String
  createdAt DateTime  @default(now())
  usedBy    String?
  usedAt    DateTime?

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  owner   Owner   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

model DriverSession {
  sessionId          String    @id @default(cuid())
  driverId           String
  vehicleId          String
  connectedAt        DateTime  @default(now())
  disconnectedAt     DateTime?
  durationMinutes    Int?
  totalTrips         Int       @default(0)
  totalKm            Float     @default(0)
  totalCashCollected Float     @default(0)

  driver  Driver  @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

enum TripLifecycleStatus {
  requested
  offered
  accepted
  driver_arriving
  driver_arrived
  trip_started
  trip_completed
  cancelled
}

enum OfferStatus {
  pending
  accepted
  rejected
  expired
  not_selected
}

enum RequestMode {
  NOW
  SCHEDULED
}

enum ScheduledStatus {
  open
  confirmed
}

model Trip {
  id                  String              @id @default(cuid())
  passengerId         String
  passengerName       String
  driverId            String?
  originJson          String
  destinationJson     String
  tripType            String
  kind                String              @default("ride")
  distanceKm          Float
  status              String              @default("searching")
  lifecycleStatus     TripLifecycleStatus @default(requested)
  passengerCount      Int                 @default(1)
  passengerOfferPrice Float?
  description         String              @default("")
  photoUrisJson       String              @default("[]")
  serviceType         ServiceType?
  cargoDetailsJson    String              @default("{}")
  requestType         String?
  deliveryCategory    String?
  businessId          String?
  businessName        String?
  acceptedOfferId     String?
  driverLat           Float?
  driverLng           Float?
  requestMode         RequestMode         @default(NOW)
  scheduledAt         DateTime?
  offerDeadlineAt     DateTime?
  pickupLatitude      Float?
  pickupLongitude     Float?
  requiredVehicleType VehicleType?
  scheduledStatus     ScheduledStatus?
  cancelledBy         String?
  createdAt           DateTime            @default(now())
  startedAt           DateTime?
  completedAt         DateTime?
  cancelledAt         DateTime?

  offers         TripOffer[]
  chatMessages   ChatMessage[]
  delivery       Delivery?
  payments       Payment[]
  locationPings  LocationPing[]

  @@index([passengerId])
  @@index([driverId])
  @@index([lifecycleStatus])
  @@index([serviceType])
  @@index([requestMode])
  @@index([scheduledStatus])
  @@index([scheduledAt])
}

model Delivery {
  id             String   @id @default(cuid())
  tripId         String   @unique
  recipientName  String?
  recipientPhone String?
  pickupNotes    String?
  deliveryNotes  String?
  packageCount   Int      @default(1)
  weightKg       Float?
  dimensionsJson String   @default("{}")
  proofPhotoUrl  String?
  signatureUrl   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model TripOffer {
  id         String      @id @default(cuid())
  tripId     String
  driverId   String
  vehicleId  String?
  driverName String
  price      Float
  etaMinutes Int
  status     OfferStatus @default(pending)
  createdAt  DateTime    @default(now())

  trip    Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  driver  Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@index([tripId])
  @@index([driverId])
  @@index([vehicleId])
}

model ChatMessage {
  id         String   @id @default(cuid())
  tripId     String
  senderId   String
  senderRole String
  senderName String
  text       String
  createdAt  DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

model TripRating {
  id        String   @id @default(cuid())
  tripId    String
  raterId   String
  raterRole String
  rateeId   String
  rateeRole String
  stars     Int
  comment   String?
  createdAt DateTime @default(now())

  @@unique([tripId, raterId, raterRole])
  @@index([tripId])
  @@index([rateeId])
}

model LocationPing {
  id        String   @id @default(cuid())
  userId    String?
  driverId  String?
  tripId    String?
  latitude  Float
  longitude Float
  accuracy  Float?
  heading   Float?
  speed     Float?
  source    String?
  createdAt DateTime @default(now())

  user   User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  driver Driver? @relation(fields: [driverId], references: [id], onDelete: Cascade)
  trip   Trip?  @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([driverId])
  @@index([tripId])
  @@index([createdAt])
}

model Payment {
  id                 String        @id @default(cuid())
  userId             String
  tripId             String?
  amount             Float
  currency           String        @default("USD")
  status             PaymentStatus @default(pending)
  provider           String
  providerPaymentId  String?
  providerCustomerId String?
  providerIntentId   String?
  providerChargeId   String?
  providerMetadataJson String      @default("{}")
  failureReason      String?
  paidAt             DateTime?
  refundedAt         DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip Trip? @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([tripId])
  @@index([status])
  @@index([provider, providerPaymentId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  dataJson  String           @default("{}")
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([readAt])
  @@index([createdAt])
}

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String
  deviceId  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
}

model SupportTicket {
  id          String                @id @default(cuid())
  userId      String
  subject     String
  description String
  status      SupportTicketStatus   @default(open)
  priority    SupportTicketPriority @default(medium)
  category    String?
  assignedTo  String?
  resolvedAt  DateTime?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([priority])
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  action     AuditAction
  entityType String
  entityId   String?
  changesJson String     @default("{}")
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model TripHistory {
  id              String   @id @default(cuid())
  tripId          String
  passengerId     String
  passengerName   String
  driverId        String
  driverName      String
  originName      String
  destinationName String
  distanceKm      Float
  price           Float
  durationMinutes Int
  status          String
  completedAt     DateTime
}

model DeliveryHistory {
  id              String   @id @default(cuid())
  deliveryId      String
  businessId      String
  businessName    String
  driverId        String
  driverName      String
  category        String
  originName      String
  destinationName String
  distanceKm      Float
  price           Float
  durationMinutes Int
  status          String
  completedAt     DateTime
}
