{
  "name": "movi-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "prebuild": "npm run db:generate",
    "build": "nest build",
    "start:prod": "node scripts/prepare-prisma.mjs && prisma migrate deploy && node dist/main.js",
    "db:prepare": "node scripts/prepare-prisma.mjs",
    "db:generate": "npm run db:prepare && prisma generate",
    "db:migrate": "npm run db:prepare && prisma migrate dev",
    "db:migrate:deploy": "npm run db:prepare && prisma migrate deploy",
    "db:push": "npm run db:prepare && prisma db push",
    "db:studio": "npm run db:prepare && prisma studio",
    "db:seed": "npm run db:prepare && tsx prisma/seed.ts",
    "prisma:validate": "npm run db:prepare && prisma validate",
    "prisma:migrate:status": "npm run db:prepare && prisma migrate status",
    "qa": "tsx scripts/qa-e2e.ts",
    "qa:critical": "tsx scripts/critical-e2e.ts",
    "qa:remote": "tsx scripts/remote-ready-e2e.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.840.0",
    "@nestjs/common": "^11.1.26",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.26",
    "@nestjs/platform-express": "^11.1.26",
    "@nestjs/platform-socket.io": "^11.1.26",
    "@nestjs/websockets": "^11.1.26",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "twilio": "^5.7.1",
    "ws": "^8.18.2",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.15.29",
    "@types/ws": "^8.18.1",
    "prisma": "^6.9.0",
    "tsx": "^4.19.4",
    "typescript": "^5.9.2"
  }
}
