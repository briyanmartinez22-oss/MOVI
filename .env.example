# MOVI — variables de entorno (raíz del proyecto / Expo)
# Copiar: cp .env.example .env

# --- Expo / app móvil (obligatorias para pruebas remotas) ---
EXPO_PUBLIC_API_URL=https://REEMPLAZAR_CON_URL_PUBLICA_DEL_BACKEND
EXPO_PUBLIC_WS_URL=wss://REEMPLAZAR_CON_URL_PUBLICA_DEL_BACKEND/ws
EXPO_PUBLIC_USE_MOCK_API=false

# --- Backend (Railway / Render — configurar en el panel del host, no en Expo) ---
# Ver plantilla completa: backend/.env.example
# PORT=3001
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/movi?schema=public
# JWT_SECRET=change-me-in-production-use-long-random-string

# --- Modo desarrollo local (simulador en misma máquina) ---
# EXPO_PUBLIC_API_URL=http://localhost:3001
# EXPO_PUBLIC_WS_URL=ws://localhost:3001/ws
# EXPO_PUBLIC_USE_MOCK_API=false

# --- Modo demo offline (sin backend) ---
# EXPO_PUBLIC_USE_MOCK_API=true
